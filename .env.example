# ============================================
# APP CONFIG
# APP_NAME drives container names and UI titles.
# Set it here or pass via ./start.sh "Your App Name"
# ============================================
APP_NAME="Town Scryer"
APP_ENV=development

# ============================================
# PORT MAPPINGS (local development)
# ============================================
BACKEND_PORT=5151
FRONTEND_PORT=3151
DB_PORT=3316
PHPMYADMIN_PORT=8080

# ============================================
# MySQL DATABASE
# ============================================
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=change_me_db_password

# ============================================
# JWT / AUTH
# ============================================
SECRET_KEY=change_me_to_a_random_string

# ============================================
# ADMIN SEED (created on first boot)
# ============================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password

# ============================================
# API URL (used by frontend)
# ============================================
VITE_API_URL=http://localhost:5151

# ============================================
# FRONTEND URL (used for email verification links)
# ============================================
FRONTEND_URL=http://localhost:3151

# ============================================
# EMAIL / SMTP (optional — logs to console if not set)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=noreply@yourapp.com

# ============================================
# DATABASE BACKUP
# ============================================
DB_BACKUP_RETENTION_DAYS=7
DB_BACKUP_COMPRESS=true

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_DISABLED=true

# ============================================
# AI / LLM
# ============================================
ANTHROPIC_API_KEY=your_key_here

# ============================================
# IMAGE GENERATION
# ============================================
IMAGE_GEN_API_KEY=your_key_here
IMAGE_GEN_PROVIDER=fal
